<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Application Status Update</title>
  <style>
    body {
      font-family: 'Arial', sans-serif;
      background-color: #f4f4f4;
      margin: 0;
      padding: 0;
    }
    .email-container {
      max-width: 600px;
      margin: 40px auto;
      background-color: #ffffff;
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }
    .email-header {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      padding: 30px 20px;
      text-align: center;
      color: #ffffff;
    }
    .email-header h1 {
      margin: 0;
      font-size: 28px;
      font-weight: bold;
    }
    .email-body {
      padding: 40px 30px;
      color: #333333;
      line-height: 1.6;
    }
    .greeting {
      font-size: 18px;
      margin-bottom: 20px;
      color: #555555;
    }
    .status-info {
      background-color: #f9f9f9;
      border-left: 4px solid #667eea;
      padding: 20px;
      margin: 20px 0;
      border-radius: 4px;
    }
    .status-info h2 {
      margin: 0 0 10px 0;
      color: #667eea;
      font-size: 22px;
    }
    .status-info p {
      margin: 5px 0;
      color: #666666;
    }
    .status-badge {
      display: inline-block;
      padding: 6px 16px;
      border-radius: 20px;
      font-weight: bold;
      font-size: 14px;
      color: #ffffff;
    }
    .status-PENDING { background-color: #f59e0b; }
    .status-REVIEWING { background-color: #3b82f6; }
    .status-INTERVIEWING { background-color: #8b5cf6; }
    .status-APPROVED { background-color: #10b981; }
    .status-REJECTED { background-color: #ef4444; }
    .cta-button {
      display: inline-block;
      padding: 15px 40px;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: #ffffff;
      text-decoration: none;
      border-radius: 5px;
      font-weight: bold;
      margin: 20px 0;
      text-align: center;
    }
    .footer {
      background-color: #f4f4f4;
      padding: 20px;
      text-align: center;
      color: #999999;
      font-size: 12px;
    }
    .footer a {
      color: #667eea;
      text-decoration: none;
    }
  </style>
</head>
<body>
  <div class="email-container">
    <div class="email-header">
      <h1>Application Status Update</h1>
    </div>

    <div class="email-body">
      <p class="greeting">Hi {{userName}},</p>

      <p>Your application status has been updated. Here are the details:</p>

      <div class="status-info">
        <h2>{{jobName}}</h2>
        <p><strong>Company:</strong> {{companyName}}</p>
        <p><strong>New Status:</strong> <span class="status-badge status-{{newStatus}}">{{newStatus}}</span></p>
      </div>

      {{#if statusMessage}}
      <p>{{statusMessage}}</p>
      {{/if}}

      <p>Click below to view your application details:</p>

      <div style="text-align: center;">
        <a href="{{applicationUrl}}" class="cta-button">View Application</a>
      </div>

      <p style="margin-top: 30px; color: #666;">
        <em>Keep checking your dashboard for further updates on your application.</em>
      </p>
    </div>

    <div class="footer">
      <p>&copy; {{currentYear}} IT Job Portal. All rights reserved.</p>
      <p>
        <a href="#">Privacy Policy</a> | 
        <a href="#">Contact Us</a>
      </p>
    </div>
  </div>
</body>
</html>
